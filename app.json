{
  "expo": {
    "name": "MediSync",
    "slug": "medisync-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "scheme": "medisync",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563EB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.medisync.mobile",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Usar Face ID para iniciar sesión",
        "NSCameraUsageDescription": "Las videoconsultas requieren acceso a la cámara",
        "NSMicrophoneUsageDescription": "Las videoconsultas requieren acceso al micrófono"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563EB"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.medisync.mobile",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "medisync"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-localization",
      "expo-web-browser",
      "expo-router",
      ["react-native-webrtc", { "videoCalling": true }]
    ],
    "extra": {
      "apiUrl": "http://localhost:4000/api",
      "router": {},
      "eas": {
        "projectId": "630f60d4-c2fb-4508-ae39-de4d14dea8e7"
      }
    },
    "owner": "lagusti285s-organization"
  }
}
